{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://pluto114-spm-asset-service.onrender.com/health"
    },
    {
      "source": "/api/v1/management/:path*",
      "destination": "https://pluto114-spm-asset-service.onrender.com/api/v1/management/:path*"
    },
    {
      "source": "/api/v1/production/:path*",
      "destination": "https://pluto114-spm-asset-service.onrender.com/api/v1/production/:path*"
    },
    {
      "source": "/api/v1/auth/:path*",
      "destination": "https://pluto114-spm-field-service.onrender.com/api/v1/auth/:path*"
    },
    {
      "source": "/api/v1/field/:path*",
      "destination": "https://pluto114-spm-field-service.onrender.com/api/v1/field/:path*"
    }
  ]
}
